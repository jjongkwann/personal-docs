# 필수: Claude API 키 (CLI 에이전트/Web UI/pkb graph build 사용 시)
# MCP만 쓸 거면 불필요 (Claude Code가 LLM 역할)
ANTHROPIC_API_KEY=your-api-key-here

# Elasticsearch
ES_HOST=http://localhost:9200
ES_INDEX=pkb_documents

# (선택) Obsidian 볼트 절대경로. 설정 시 pkb init 초기 인제스트, pkb watch 자동 동기화
# OBSIDIAN_PATH=/Users/me/Documents/ObsidianVault

# 검색 파이프라인
FUSION=rrf                  # rrf | native
RERANK_ENABLED=true
CANDIDATE_K=50
EXPAND_CONTEXT=0            # N>0이면 검색 결과마다 전후 N청크를 neighbors로 부착

# 개념 그래프 (Graph RAG)
GRAPH_DB_PATH=data/.graph/pkb_graph.sqlite
GRAPH_EXTRACT_MODEL=claude-haiku-4-5-20251001
GRAPH_DEDUP_THRESHOLD=0.88
